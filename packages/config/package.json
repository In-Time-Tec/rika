{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun --format esm --external effect --external 'effect/*'",
    "lint": "bun --cwd ../.. node_modules/oxlint/dist/cli.js packages/config/src packages/config/test",
    "typecheck": "bun ../../node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
