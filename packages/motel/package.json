{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/motel",
  "version": "0.2.6-rika.0",
  "description": "Rika-owned fork of motel, a local OpenTelemetry ingest and TUI viewer.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Kit Langton",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitlangton/motel.git"
  },
  "bin": {
    "motel": "src/motel.ts",
    "motel-mcp": "src/mcp.ts"
  },
  "scripts": {
    "build": "bun build ./src/motel.ts --outdir dist --target bun --format esm --external @opentui/core-darwin-arm64 --external @opentui/core-darwin-x64 --external @opentui/core-linux-arm64 --external @opentui/core-linux-arm64-musl --external @opentui/core-linux-x64 --external @opentui/core-linux-x64-musl --external @opentui/core-win32-arm64 --external @opentui/core-win32-x64",
    "dev": "MOTEL_OTEL_ENABLED=true bun run src/motel.ts tui",
    "start": "bun run src/motel.ts tui",
    "daemon": "bun run src/motel.ts daemon",
    "status": "bun run src/motel.ts status",
    "stop": "bun run src/motel.ts stop",
    "restart": "bun run src/motel.ts restart",
    "server": "bun run src/motel.ts server",
    "mcp": "bun run src/mcp.ts",
    "cli": "bun run src/cli.ts",
    "test": "bun test --pass-with-no-tests $(find src -name '*.test.ts' ! -name '*.repro.test.ts' | sort)",
    "typecheck": "bun tsc --noEmit --noCheck"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.90",
    "@effect/opentelemetry": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/exporter-logs-otlp-http": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/otlp-transformer": "0.214.0",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentui/core": "0.4.2",
    "@opentui/react": "0.4.2",
    "effect": "catalog:",
    "protobufjs": "7.6.4",
    "react": "^19.2.7",
    "scheduler": "^0.27.0"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/react": "^19.2.17",
    "typescript": "catalog:"
  }
}
